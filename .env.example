# These become GitHub Actions repo secrets (Settings -> Secrets) for the tick.
# NOTION_TOKEN + POST_QUEUE_DB_ID additionally go into ~/cross-platform-poster/.env
# on Zo for the hourly watchdog.
NOTION_TOKEN=            # cross-platform-poster Notion integration token
POST_QUEUE_DB_ID=        # printed by setup_notion.py
YT_CLIENT_ID=            # Google Cloud OAuth (Desktop app) client id
YT_CLIENT_SECRET=        # Google Cloud OAuth client secret
YT_REFRESH_TOKEN=        # minted once via scripts/get_youtube_token.py
IG_USER_ID=              # Instagram Business account id
IG_ACCESS_TOKEN=         # Instagram-Login long-lived token; rotated monthly by refresh-ig-token.yml
ASSET_STORE_TOKEN=       # optional X-Token for downloading from um-assets
